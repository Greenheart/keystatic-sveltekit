{
  "name": "keystatic-sveltekit",
  "description": "Keystatic CMS integration for SvelteKit",
  "version": "1.2.0",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Samuel Plumppu",
    "url": "https://samuelplumppu.se"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Greenheart/keystatic-sveltekit.git"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "prepublishOnly": "pnpm build",
    "prepack": "svelte-kit sync && svelte-package && publint",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check ."
  },
  "dependencies": {
    "rolldown": "^1.2.0"
  },
  "peerDependencies": {
    "@keystatic/core": "^0.5.51",
    "@sveltejs/kit": "2.70.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vite": "^8.0.0"
  },
  "devDependencies": {
    "@keystatic/core": "^0.5.51",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "2.70.0",
    "@sveltejs/package": "^2.5.8",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "markdoc-svelte": "^4.2.0",
    "prettier": "^3.9.5",
    "prettier-plugin-svelte": "^4.1.1",
    "publint": "^0.3.21",
    "svelte": "^5.56.6",
    "svelte-check": "^4.7.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "zod": "^4.4.3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 100,
    "plugins": [
      "prettier-plugin-svelte"
    ],
    "overrides": [
      {
        "files": "*.svelte",
        "options": {
          "parser": "svelte"
        }
      }
    ]
  }
}
